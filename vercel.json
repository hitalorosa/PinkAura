{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/",      "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/admin(.*)",
      "headers": [
        { "key": "X-Robots-Tag",       "value": "noindex, nofollow" },
        { "key": "X-Frame-Options",     "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
